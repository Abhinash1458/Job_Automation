# Secrets
.env

# Virtual environment
.venv/
venv/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# Local data (raw resume, scraped jobs, drafts, tracker DB, browser profile, logs)
data/resume/*
!data/resume/.gitkeep
data/jobs.db
data/drafts/*
!data/drafts/.gitkeep
data/raw/*
!data/raw/.gitkeep
data/applications/*
!data/applications/.gitkeep
data/logs/
data/.browser/

# Personal data — MUST stay out of the (public) repo.
# profile.json is provided to CI via the PROFILE_JSON GitHub Secret instead.
data/profile.json
*.pdf
data/reports/*
!data/reports/.gitkeep
# LATEST_MATCHES.md IS committed by CI so you can view it as one page on GitHub.
# It contains only job listings + fit notes (no resume / contact details).
