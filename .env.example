# ---------------------------------------------------------------------------
# Copy this file to ".env" and fill in your values. Never commit ".env".
# ---------------------------------------------------------------------------

# --- Claude API (required: powers resume parsing, matching, tailoring) ------
# Get a key at https://console.anthropic.com/  ->  Settings -> API Keys
ANTHROPIC_API_KEY=

# Model + effort (sensible defaults; leave as-is unless you know otherwise)
CLAUDE_MODEL=claude-opus-4-8

# --- Apify (optional: paid job-board scraping) ------------------------------
# Sign up at https://apify.com/  ->  Settings -> Integrations -> API token
# Leave blank to use the free scraper instead.
APIFY_TOKEN=
# Actor that scrapes jobs. Default is a popular LinkedIn jobs actor.
# Any actor that returns a list of job objects works; map fields in scrapers/apify_scraper.py
APIFY_JOBS_ACTOR=bebity/linkedin-jobs-scraper

# --- Job search preferences -------------------------------------------------
JOB_KEYWORDS=Python Developer, Backend Engineer, Data Engineer
JOB_LOCATION=India
JOB_REMOTE=true
# Only consider jobs scoring at or above this (0-100) for auto-apply / outreach
MATCH_THRESHOLD=70
# Max jobs to process per run
MAX_JOBS_PER_RUN=25

# --- Your contact details (used to fill applications + sign emails) ---------
FULL_NAME=Abhinash Neelapalli
EMAIL=neelapalliabhinash1458@gmail.com
PHONE=
LINKEDIN_URL=
PORTFOLIO_URL=
GITHUB_URL=

# --- Email drafting (drafts only; you review + send manually) ---------------
# Drafts are written as .eml files to data/drafts/ that you can open in any mail client.
# Optionally also push them to Gmail "Drafts" via an app password (see README).
GMAIL_ADDRESS=neelapalliabhinash1458@gmail.com
# 16-char Google App Password (NOT your normal password). Leave blank to skip Gmail push.
# https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=
